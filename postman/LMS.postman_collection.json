{
  "info": {
    "name": "Leave Management System API",
    "description": "Complete API collection for the Employee Leave Management System.\n\n**Setup:**\n1. Import this collection into Postman\n2. Import `LMS.postman_environment.json` as the environment\n3. Run `POST /auth/login` — the access token is saved automatically\n4. All subsequent requests use `{{accessToken}}` from the environment",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "leaveId", "value": "1", "type": "string" },
    { "key": "employeeId", "value": "2", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login — Employee",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  console.log('Token saved:', json.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@company.com\",\n  \"password\": \"Employee@123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login — Manager",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"manager@company.com\",\n  \"password\": \"Manager@123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/employees/profile", "host": ["{{baseUrl}}"], "path": ["employees", "profile"] }
          }
        },
        {
          "name": "Get All Employees (Manager)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/employees?page=1&limit=10&search=",
              "host": ["{{baseUrl}}"],
              "path": ["employees"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "search", "value": "" }
              ]
            }
          }
        },
        {
          "name": "Get Employee by ID (Manager)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/employees/{{employeeId}}", "host": ["{{baseUrl}}"], "path": ["employees", "{{employeeId}}"] }
          }
        }
      ]
    },
    {
      "name": "Leaves",
      "item": [
        {
          "name": "Apply for Leave",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('leaveId', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leaveType\": \"CASUAL\",\n  \"startDate\": \"2025-12-01\",\n  \"endDate\": \"2025-12-03\",\n  \"reason\": \"Family function\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/leaves", "host": ["{{baseUrl}}"], "path": ["leaves"] }
          }
        },
        {
          "name": "Get My Leaves",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/leaves?page=1&limit=10&status=&leaveType=&search=",
              "host": ["{{baseUrl}}"],
              "path": ["leaves"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "status", "value": "" },
                { "key": "leaveType", "value": "" },
                { "key": "search", "value": "" }
              ]
            }
          }
        },
        {
          "name": "Get Leave by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/leaves/{{leaveId}}", "host": ["{{baseUrl}}"], "path": ["leaves", "{{leaveId}}"] }
          }
        },
        {
          "name": "Update Pending Leave",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leaveType\": \"SICK\",\n  \"startDate\": \"2025-12-01\",\n  \"endDate\": \"2025-12-02\",\n  \"reason\": \"Not feeling well\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/leaves/{{leaveId}}", "host": ["{{baseUrl}}"], "path": ["leaves", "{{leaveId}}"] }
          }
        },
        {
          "name": "Cancel Pending Leave",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/leaves/{{leaveId}}", "host": ["{{baseUrl}}"], "path": ["leaves", "{{leaveId}}"] }
          }
        },
        {
          "name": "Get Pending Leaves (Manager)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/leaves/pending?page=1&limit=10&search=",
              "host": ["{{baseUrl}}"],
              "path": ["leaves", "pending"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "search", "value": "" }
              ]
            }
          }
        },
        {
          "name": "Approve Leave (Manager)",
          "request": {
            "method": "PUT",
            "header": [],
            "url": { "raw": "{{baseUrl}}/leaves/{{leaveId}}/approve", "host": ["{{baseUrl}}"], "path": ["leaves", "{{leaveId}}", "approve"] }
          }
        },
        {
          "name": "Reject Leave (Manager)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"managerComments\": \"Insufficient staffing during that period\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/leaves/{{leaveId}}/reject", "host": ["{{baseUrl}}"], "path": ["leaves", "{{leaveId}}", "reject"] }
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Employee Dashboard",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/leaves/dashboard/employee", "host": ["{{baseUrl}}"], "path": ["leaves", "dashboard", "employee"] }
          }
        },
        {
          "name": "Manager Dashboard",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/leaves/dashboard/manager", "host": ["{{baseUrl}}"], "path": ["leaves", "dashboard", "manager"] }
          }
        }
      ]
    }
  ]
}
